generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  username     String   @unique
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workouts        Workout[]
  routines        Routine[]
  routineFolders  RoutineFolder[]
  createdExercises Exercise[]       @relation("UserExercises")
  personalRecords PersonalRecord[]
}

model Exercise {
  id              String   @id @default(cuid())
  name            String
  muscleGroups    String[]
  equipment       String?
  instructions    String?
  videoUrl        String?
  isCustom        Boolean  @default(false)
  createdByUserId String?
  createdBy       User?    @relation("UserExercises", fields: [createdByUserId], references: [id], onDelete: SetNull)

  workoutExercises WorkoutExercise[]
  routineExercises RoutineExercise[]
  personalRecords  PersonalRecord[]
}

model Workout {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  routineId  String?
  title      String
  notes      String?
  startedAt  DateTime
  finishedAt DateTime?
  isPublic   Boolean   @default(false)

  workoutExercises WorkoutExercise[]
}

model WorkoutExercise {
  id         String  @id @default(cuid())
  workoutId  String
  workout    Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  order      Int
  supersetId String?

  sets Set[]
}

model Set {
  id                String          @id @default(cuid())
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  reps              Int?
  weightKg          Float?
  setType           String          @default("normal")
  rpe               Float?
  createdAt         DateTime        @default(now())
}

model RoutineFolder {
  id       String    @id @default(cuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String
  routines Routine[]
}

model Routine {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  folderId    String?
  folder      RoutineFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  routineExercises RoutineExercise[]
}

model RoutineExercise {
  id         String   @id @default(cuid())
  routineId  String
  routine    Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  order      Int
  setsConfig Json     @default("[]")
}

model PersonalRecord {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  weightKg   Float
  reps       Int
  oneRepMax  Float
  createdAt  DateTime @default(now())
}
